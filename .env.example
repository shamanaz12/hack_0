# MCP Server Configuration
# Copy this file to .env and fill in your actual values

# =============================================================================
# Gmail/SMTP Settings (for email MCP)
# =============================================================================
EMAIL_ADDRESS=your-email@gmail.com
EMAIL_PASSWORD=your-app-password-here
SMTP_SERVER=smtp.gmail.com
SMTP_PORT=587

# =============================================================================
# Odoo Settings (for Odoo MCP)
# =============================================================================
ODOO_URL=http://localhost:8069
ODOO_DB=your-database-name
ODOO_USERNAME=admin
ODOO_PASSWORD=your-password

# =============================================================================
# Orchestrator Settings
# =============================================================================
VAULT_PATH=.
MAX_ITERATIONS=10
POLL_INTERVAL=5

# Watcher Intervals (seconds)
GMAIL_INTERVAL=300
WHATSAPP_INTERVAL=300
ORCHESTRATOR_INTERVAL=60

# Feature Flags
AUTO_RUN_WATCHERS=true
ENABLE_MCP_EMAIL=true

# Default email for approvals (optional)
DEFAULT_EMAIL=
